PORT=3001
MONGODB_URI=mongodb://127.0.0.1:27017/tradeking
# Optional: require X-API-Key on /api/v1/levels and /api/v1/kite (trading bot / scripts)
API_KEY=
# Dashboard login for apps/Web (JWT session). If set, Web must POST /api/v1/auth/login first.
DASHBOARD_USER_ID=
DASHBOARD_PASSWORD=
# Min 16 chars; used to sign JWT (keep secret)
WEB_SESSION_SECRET=
# Kite Connect app API key (public); used to build GET /api/v1/kite/login-url — same as KITE_API_KEY in trading bot
KITE_API_KEY=
