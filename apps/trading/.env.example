KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=
KITE_ACCESS_DATE=
DB_PATH=./storage/scalping_bot.db
LOG_LEVEL=INFO
MAX_TRADES_BEFORE_LOCK=2
MAX_CANDLES_DEFAULT=10
EOD_SQUAREOFF_TIME=15:15
DRY_RUN=true
# Levels API (Node apps/Api). Bot loads GET /api/v1/levels/{date} from daily_config.json date.
# When a fresh Kite session is needed, the bot loads the request_token from GET /api/v1/kite/request-token (save via apps/Web).
LEVELS_API_URL=http://localhost:3001
# Optional; must match API API_KEY if set
LEVELS_API_KEY=
