KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=
DB_PATH=./storage/scalping_bot.db
LOG_LEVEL=INFO
MAX_TRADES_BEFORE_LOCK=2
MAX_CANDLES_DEFAULT=10
MARKET_START_TIME=09:15
MARKET_END_TIME=15:30
EOD_SQUAREOFF_TIME=15:15
DRY_RUN=true
MONGO_EVENTS_ENABLED=false
MONGO_EVENTS_URI=mongodb://127.0.0.1:27017
MONGO_EVENTS_DB=tradeking
MONGO_EVENTS_COLLECTION=bot_events
MONGO_EVENTS_BATCH_SIZE=100
# TradeKing Node API (MongoDB). Base URL for levels + Kite request_token on the same host/port.
TRADEKING_API_URL=http://localhost:3001
# Legacy alias (optional if TRADEKING_API_URL is set)
# LEVELS_API_URL=http://localhost:3001
# Optional; default auth/token_cache.json — Docker compose sets /app/storage/kite_token_cache.json
# KITE_TOKEN_CACHE_PATH=
