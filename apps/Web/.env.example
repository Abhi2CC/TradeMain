# Base URL of the Levels API (no trailing slash)
VITE_API_URL=http://localhost:3001
# Show the id/password screen first (default true). Set false for API_KEY-only dev (no dashboard env on server).
VITE_REQUIRE_LOGIN=true
# If the API uses only X-API-Key (and VITE_REQUIRE_LOGIN=false), set the same key here
VITE_API_KEY=
