# Copy to project root as `.env` for docker compose (do not commit `.env`).

# --- Mongo (default matches compose service name `mongo`) ---
MONGODB_URI=mongodb://mongo:27017/tradeking

# --- apps/Api (see apps/Api/.env.example) ---
# API_KEY=
# DASHBOARD_USER_ID=
# DASHBOARD_PASSWORD=
# Min 16 chars in production
# WEB_SESSION_SECRET=
# KITE_API_KEY=

# --- apps/Web build args (baked at image build time) ---
# Relative API via nginx proxy (default)
# VITE_API_URL=same
# VITE_API_KEY=
# VITE_REQUIRE_LOGIN=true

# Host port for dashboard (nginx)
WEB_PUBLISH_PORT=8080

# --- Trading bot (docker compose --profile bot); optional env overrides ---
# BOT_LOG_LEVEL=INFO
# BOT_DRY_RUN=true
# BOT_EOD_SQUAREOFF_TIME=15:15
# KITE_API_SECRET=
# KITE_ACCESS_TOKEN=
# KITE_ACCESS_DATE=
